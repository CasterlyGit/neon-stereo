# Spotify Developer credentials
# Register an app at https://developer.spotify.com/dashboard
# Redirect URI to register: http://127.0.0.1:53682/callback
SPOTIFY_CLIENT_ID=your-spotify-client-id-here

# Demo mode — boots straight to a synthetic Dashboard without Spotify auth.
# Strict equality: only the literal string "1" enables it. No keychain reads/writes.
# NEON_DEMO=1

# Default provider at boot. Overrides the persisted preferences file.
# One of: spotify | youtube | demo. Ignored when NEON_DEMO=1.
# NEON_DEFAULT_PROVIDER=spotify

# YouTube Data API key — placeholder for v2 in-app search.
# v1 plays public YouTube videos via the IFrame Player API and needs no API key.
# YOUTUBE_API_KEY=
